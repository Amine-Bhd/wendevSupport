        svcfe["Service frontend"]
        svcapi["Service backend"]
        svcdb["Service PostgreSQL"]
        ing["Ingress\npoint d'entrée HTTP"]
        pvc["PersistentVolumeClaim\nstockage PostgreSQL"]
